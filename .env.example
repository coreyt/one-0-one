# one-0-one environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit API keys.

# --- LLM Provider API Keys ---
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-proj-
MISTRAL_API_KEY=e3
GOOGLE_AISTUDIO_API_KEY=

# GOOGLE_VERTEX_API_KEY=AQ.

# Local LiteLLM router (airlock)
LITELLM_ROUTER_URL=http://localhost:4000

# Paths
SESSIONS_PATH=./sessions
LOGS_PATH=./logs
SESSION_TEMPLATES_PATH=./session-templates

# Transcript checkpoint frequency (events between checkpoint flushes)
TRANSCRIPT_CHECKPOINT_INTERVAL=10

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
