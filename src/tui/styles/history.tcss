/* ====================================================================
   SessionHistoryScreen styles
   ==================================================================== */

SessionHistoryScreen {
    layout: vertical;
}

#history-split {
    height: 1fr;
}

#history-list {
    width: 1fr;
    max-width: 50;
    min-width: 30;
    border-right: solid $panel;
}

#transcript-view {
    width: 2fr;
    padding: 1 2;
    scrollbar-size: 1 1;
}
