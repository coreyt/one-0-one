/* ====================================================================
   SetupWizardScreen styles
   ==================================================================== */

SetupWizardScreen {
    layout: vertical;
}

#wizard-tabs {
    height: 3;
}

#topic-pane,
#setting-pane,
#agents-pane,
#orchestrator-pane,
#hitl-pane {
    height: 1fr;
    padding: 1 2;
    overflow-y: auto;
}

.field-label {
    margin-top: 1;
    text-style: bold;
}

.field-error {
    color: $error;
    text-style: italic;
}

.section-header {
    margin-top: 2;
    text-style: bold underline;
    color: $accent;
}

#validation-error {
    height: auto;
    min-height: 1;
    padding: 0 2;
}

/* Agent tab */
#agents-table {
    height: 12;
    margin-bottom: 1;
}

#agent-buttons {
    height: 3;
}

#agent-buttons Button {
    margin-right: 1;
}

/* Orchestrator conditional sections */
#orch-python-section,
#orch-llm-section {
    padding: 0;
}

/* Game config section */
#game-config-section {
    padding: 0;
    border-top: solid $panel;
    margin-top: 1;
}

/* Advanced / transcript sections */
#advanced-section,
#transcript-section {
    padding: 0;
    border-top: solid $panel;
    margin-top: 1;
}

/* HITL settings section */
#hitl-settings-section {
    padding: 0;
}
